#include <iostream>
#include <string>
using namespace std;

int main() {
    string texto;
    int contador = 0;
    
    cout << "Ingrese un texto: ";
    getline(cin, texto);

    for (int i = 0; texto[i] != '\0'; i++) {
        contador++;
    }

    cout << "El texto ingresado tiene " << contador << " caracteres." << endl;

    return 0;
}
