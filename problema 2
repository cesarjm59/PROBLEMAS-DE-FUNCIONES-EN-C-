//4 operaciones aritmeticas/suma, resta, división y multiplicación)
#include <iostream>
using namespace std;

double division(double a, double b){
    return a/b;
} 

int producto(int a, int b){
    return a*b;
} 

int resta(int a, int b){
    return a-b;
} 
int sumar(int a, int b){
    return a+b;
}    
